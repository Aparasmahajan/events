# --- Google ---
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
TOKEN_SALT=
# Single admin v1. Generate hash with:
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');c.scrypt('YOUR_PASSWORD',s,64,(_,h)=>console.log(s+':'+h.toString('hex')))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# Optional session tuning
OTP_TTL_MIN=10
SESSION_TTL_CUSTOMER_DAYS=30
SESSION_TTL_ADMIN_HOURS=8

# --- Email (for customer OTPs) ---
# If empty, the OTP is logged to the server console as [DEV OTP] ... so local
# testing works without an email account.
RESEND_API_KEY=
MAIL_FROM=Event Platform <no-reply@example.com>

# --- Misc ---
REVALIDATE_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
