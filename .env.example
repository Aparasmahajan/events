# --- Google Sheets (data store) ---
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Cloudinary (media host — PRODUCTION) ---
# Sign up at https://cloudinary.com — free tier is 25 credits/month.
# Dashboard → Settings → API Keys. Use a server-side ("Sending") key.
#
# Dev on a Windows laptop? Leave these empty and uploads save to
# `public/uploads/{EventCode}/{section}/` automatically — served by
# Next's static file handler. No cloud account needed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
TOKEN_SALT=
# Single admin v1. Generate hash with:
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');c.scrypt('YOUR_PASSWORD',s,64,(_,h)=>console.log(s+':'+h.toString('hex')))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# Optional session tuning
OTP_TTL_MIN=10
SESSION_TTL_CUSTOMER_DAYS=30
SESSION_TTL_ADMIN_HOURS=8

# OTP-request rate limit per source IP per hour. Default 5.
LOGIN_IP_LIMIT_PER_HOUR=5

# --- Email (for customer OTPs) ---
# If empty, the OTP is logged to the server console as [DEV OTP] ... so local
# testing works without an email account.
RESEND_API_KEY=
MAIL_FROM=Event Platform <no-reply@example.com>

# --- Misc ---
REVALIDATE_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
